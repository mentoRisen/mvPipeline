# Copy to mcp-mysql.env in this directory (never commit mcp-mysql.env).
# one file per clone / per environment — each project repo keeps its own values.
#
# Required for mcp-server-mysql:
MYSQL_USER=mvpipeline_read
MYSQL_PASS=replace-me
#
# Optional overrides (defaults match app DB):
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=mvpipeline
MCP_DB_NAME=mvpipeline
#
# Remote-SSH from laptop: open a tunnel, then set port to the local forward, e.g.
#   ssh -N -L 13306:127.0.0.1:3306 you@server
#   MYSQL_PORT=13306
